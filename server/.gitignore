# =========================
# BACKEND .gitignore
# =========================

# Dependencies
node_modules/

# Environment variables
.env
.env.*
!.env.example
!.env.sample

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Build output
dist/
build/

# Coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp

# Cache
.cache/
.eslintcache

# Process files
*.pid
*.seed
*.pid.lock

# Local databases
*.db
*.sqlite
*.sqlite3

# MongoDB local files (if stored locally)
mongodb-data/
mongo-data/

# Uploads (optional)
uploads/
public/uploads/

# Generated exports
exports/
backups/

# PM2
.pm2/
pids/

# TypeScript
*.tsbuildinfo

# Swagger generated docs
swagger.json

# Certificates
*.pem
*.key
*.crt

# Docker
docker-compose.override.yml

# Test results
junit.xml

# Mac/Linux
.DS_Store

# Windows
Thumbs.db

# IDEs
.vscode/
.idea/

# Debug files
*.stackdump

# dotenv files
.env.local
.env.development.local
.env.test.local
.env.production.local

node_modules/
dist/
coverage/
.env
.env.local
*.log
.DS_Store
.mongodb-binaries/
