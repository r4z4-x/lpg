# Copy to .env and adjust. All values validated at boot (src/config/env.ts).
NODE_ENV=development
PORT=4000

# MongoDB MUST be a replica set (transactions are mandatory).
# Local dev via docker-compose (see README): single-node replica set rs0.
MONGODB_URI=mongodb://127.0.0.1:27017/lpg_dev?replicaSet=rs0&directConnection=true

# Business timezone for day/month bucketing (today/monthly reports).
BUSINESS_TIMEZONE=Asia/Karachi

LOG_LEVEL=info

# Auth (M1).
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# Bootstrap owner (created by `npm run seed` only if no owner exists). Change immediately.
OWNER_NAME=Owner
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=changeme123
